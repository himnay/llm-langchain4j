{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "title": "LLM Chat",
  "uid": "llm-chat",
  "tags": [
    "chat",
    "spring-ai"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "prometheus"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP request rate (req/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (uri, status) (rate(http_server_requests_seconds_count{application=\"llm-chat\"}[1m]))",
          "legendFormat": "{{uri}} ({{status}})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p95 (s)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{application=\"llm-chat\"}[5m])))",
          "legendFormat": "p95 {{uri}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP error rate (4xx/5xx req/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{application=\"llm-chat\", status=~\"4..|5..\"}[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM heap used (bytes)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (area) (jvm_memory_used_bytes{application=\"llm-chat\"})",
          "legendFormat": "{{area}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Process CPU usage",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"llm-chat\"}",
          "legendFormat": "process"
        },
        {
          "expr": "system_cpu_usage{application=\"llm-chat\"}",
          "legendFormat": "system"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Live JVM threads",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"llm-chat\"}",
          "legendFormat": "live"
        }
      ]
    }
  ]
}
